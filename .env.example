# ============================================================
# ElevatorAI - Environment Configuration
# ============================================================
# This project uses Google AI Studio (Gemini API Key) only.
# NO Google Cloud Project or Vertex AI required.

# --- Required: Gemini API Key (from Google AI Studio) ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Required: Database ---
# Use local PostgreSQL for development:
DATABASE_URL=postgresql://postgres:postgres@db:5432/elevatorai_adk
# For production (Supabase, Neon, etc.):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# --- Required: Redis ---
# Use local Redis for development:
REDIS_URL=redis://redis:6379/0
# For production (Upstash, etc.):
# REDIS_URL=rediss://default:[PASSWORD]@[HOST]:6379

# --- Optional: WhatsApp Business API ---
# If not provided, quotes are generated but not sent via WhatsApp
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# --- Application Settings ---
DEBUG=false
SECRET_KEY=your-secret-key-here-change-in-production
# Frontend URL (for CORS and WhatsApp callbacks)
FRONTEND_URL=http://localhost:3000

# --- 3D Asset Paths ---
MODEL_OUTPUT_PATH=./static/models/
TEXTURE_PATH=./static/textures/
